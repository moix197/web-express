# Controls the canonical base URL used throughout the site.
# Setting this variable causes ALL of the following to reflect the new domain:
#   - Canonical URL (Next.js metadataBase → <link rel="canonical">)
#   - Sitemap (next-sitemap / Next.js sitemap.ts)
#   - robots.txt host declaration
#   - JSON-LD structured data `url` fields (LocalBusiness, Service provider)
#   - Footer copyright domain text
#   - OG image domain badge text
#
# Useful for staging / preview deployments:
#   NEXT_PUBLIC_SITE_URL=https://staging.example.com
#
# Defaults to https://web-express.com.ar when unset.
NEXT_PUBLIC_SITE_URL=https://web-express.com.ar
